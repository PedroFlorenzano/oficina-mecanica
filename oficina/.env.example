# ============================================================
# PostgreSQL — Banco de dados
# ============================================================

# Conexão principal (com pooling) — usada pela aplicação em runtime
DATABASE_URL="postgresql://neondb_owner:SENHA@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Conexão direta (sem pooling) — usada pelo Prisma para migrations
DIRECT_URL="postgresql://neondb_owner:SENHA@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# Admin_Role — BYPASSRLS — uso EXCLUSIVO em operações cross-tenant (dev local)
# Em produção no Neon, usar a mesma DATABASE_URL (owner já tem BYPASSRLS)
DATABASE_URL_ADMIN="postgresql://neondb_owner:SENHA@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# NextAuth
# ============================================================
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# Evolution API (WhatsApp)
# ============================================================
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE=""

# ============================================================
# Cron (lembrete preventivo)
# ============================================================
CRON_SECRET=""
